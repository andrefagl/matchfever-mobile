{
    "extends": "expo-module-scripts/tsconfig.plugin",
    "compilerOptions": {
        "outDir": "build",
        "rootDir": "src",
        "module": "CommonJS",
        "moduleResolution": "node",
        "target": "ES2020"
    },
    "include": ["./src"],
    "exclude": ["**/__mocks__/*", "**/__tests__/*"]
}
