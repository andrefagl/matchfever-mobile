{
    "cli": {
        "version": ">= 16.18.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "distribution": "internal"
        },
        "production": {
            "autoIncrement": true
        },
        "development-simulator": {
            "extends": "development",
            "ios": {
                "simulator": true
            },
            "environment": "development"
        }
    },
    "submit": {
        "production": {}
    }
}
